# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
# Keypair оператора читается из keys/devnet-authority.json (лежит в репо)
# Можно переопределить через BACKEND_KEYPAIR_PATH или BACKEND_PRIVATE_KEY (base64)

# USDT_MINT автоматически заполняется при запуске `anchor run init-devnet`
USDT_MINT=

# Sumsub (опционально — без ключей работает mock KYC)
SUMSUB_APP_TOKEN=<your-sumsub-app-token>
SUMSUB_SECRET_KEY=<your-sumsub-secret-key>
SUMSUB_WEBHOOK_SECRET=<your-sumsub-webhook-secret>
SUMSUB_BASE_URL=https://api.sumsub.com

# Server
PORT=4000
NODE_ENV=development
